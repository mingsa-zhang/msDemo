<Window x:Class="DataAgentRetryTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:System="clr-namespace:System;assembly=mscorlib"
        Title="数据传输重推工具" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0"
                   Text="数据传输重推工具"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#333333"
                   Margin="0,0,0,15"/>

        <!-- Tab页区域 -->
        <TabControl Grid.Row="1" Background="White">
            <!-- 正式环境Tab -->
            <TabItem Header="正式环境" x:Name="ProductionTab">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 配置区域 -->
                    <GroupBox Grid.Row="0"
                              Header="配置"
                              Background="White"
                              Padding="15"
                              Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Token输入 -->
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="授权Token："
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,10"/>
                            <TextBox Grid.Row="0" Grid.Column="1"
                                     x:Name="ProductionTokenTextBox"
                                     Height="30"
                                     Margin="0,0,0,10"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Disabled"/>

                            <!-- 查询条件说明 -->
                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="查询条件："
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Text="BusinessTypeId: 1957628687581773824 | 【新-部】客户修改 | TransferState: 4"
                                       VerticalAlignment="Center"
                                       Foreground="#666"/>
                        </Grid>
                    </GroupBox>

                    <!-- 操作按钮 -->
                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                Margin="0,0,0,10">
                        <Button Content="查询数据"
                                Style="{StaticResource PrimaryButton}"
                                Click="ProductionQueryButton_Click"
                                x:Name="ProductionQueryButton"
                                Margin="0,0,10,0"/>
                        <Button Content="开始自动重推"
                                Style="{StaticResource PrimaryButton}"
                                Click="ProductionStartRetryButton_Click"
                                x:Name="ProductionStartRetryButton"
                                IsEnabled="False"
                                Margin="0,0,10,0"/>
                        <Button Content="停止重推"
                                Style="{StaticResource PrimaryButton}"
                                Click="ProductionStopRetryButton_Click"
                                x:Name="ProductionStopRetryButton"
                                IsEnabled="False"
                                Background="#D13438"
                                Margin="0,0,10,0"/>
                        <Button Content="清空日志"
                                Style="{StaticResource PrimaryButton}"
                                Click="ProductionClearLogButton_Click"
                                Background="#666666"
                                Margin="0,0,10,0"/>
                        <Button Content="清空推送记录"
                                Style="{StaticResource PrimaryButton}"
                                Click="ClearRecordsButton_Click"
                                Background="#FF8C00"/>
                        <TextBlock x:Name="ProductionStatusTextBlock"
                                   Text="就绪"
                                   VerticalAlignment="Center"
                                   Margin="20,0,0,0"
                                   Foreground="#666"/>
                        <TextBlock x:Name="ProductionCountTextBlock"
                                   Text="总记录数: 0"
                                   VerticalAlignment="Center"
                                   Margin="20,0,0,0"
                                   Foreground="#333"/>
                    </StackPanel>

                    <!-- 日志显示区域 - 单面板 -->
                    <GroupBox Grid.Row="2"
                              Background="White"
                              Padding="5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#0078D4" Padding="8,4">
                                <TextBlock Text="正式环境 - 【新-部】客户修改" Foreground="White" FontWeight="Bold"/>
                            </Border>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5,2">
                                <TextBlock x:Name="ProductionStatInit" Text="初次:0" Foreground="#999" Margin="0,0,15,0"/>
                                <TextBlock x:Name="ProductionStat" Text="剩余:0 成功:0 跳过:0 失败:0 取消:0" Foreground="#666"/>
                            </StackPanel>
                            <TextBox Grid.Row="2"
                                     x:Name="ProductionLogTextBox"
                                     IsReadOnly="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     FontSize="11"
                                     Background="#1E1E1E"
                                     Foreground="#4EC9B0"
                                     TextWrapping="NoWrap"/>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- 测试环境Tab -->
            <TabItem Header="测试环境" x:Name="TestTab">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 配置区域 -->
                    <GroupBox Grid.Row="0"
                              Header="配置"
                              Background="White"
                              Padding="15"
                              Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Token输入 -->
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="授权Token："
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,10"/>
                            <TextBox Grid.Row="0" Grid.Column="1"
                                     x:Name="TestTokenTextBox"
                                     Height="30"
                                     Margin="0,0,0,10"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Disabled"/>

                            <!-- 查询条件说明 -->
                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="查询条件："
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Text="BusinessTypeId: 1905147715017936896 | 【正式】客户修改 | TransferState: 4"
                                       VerticalAlignment="Center"
                                       Foreground="#666"/>
                        </Grid>
                    </GroupBox>

                    <!-- 操作按钮 -->
                    <GroupBox Grid.Row="1"
                              Header="自动重推（传输失败）"
                              Background="White"
                              Padding="10"
                              Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="查询数据"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="TestQueryButton_Click"
                                    x:Name="TestQueryButton"
                                    Margin="0,0,10,0"/>
                            <Button Content="开始自动重推"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="TestStartRetryButton_Click"
                                    x:Name="TestStartRetryButton"
                                    IsEnabled="False"
                                    Margin="0,0,10,0"/>
                            <Button Content="停止重推"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="TestStopRetryButton_Click"
                                    x:Name="TestStopRetryButton"
                                    IsEnabled="False"
                                    Background="#D13438"
                                    Margin="0,0,10,0"/>
                            <Button Content="清空日志"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="TestClearLogButton_Click"
                                    Background="#666666"
                                    Margin="0,0,10,0"/>
                            <Button Content="清空推送记录"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="ClearRecordsButton_Click"
                                    Background="#FF8C00"/>
                            <TextBlock x:Name="TestStatusTextBlock"
                                       Text="就绪"
                                       VerticalAlignment="Center"
                                       Margin="20,0,0,0"
                                       Foreground="#666"/>
                            <TextBlock x:Name="TestCountTextBlock"
                                       Text="总记录数: 0"
                                       VerticalAlignment="Center"
                                       Margin="20,0,0,0"
                                       Foreground="#333"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- 按时间条件重推区域 -->
                    <GroupBox Grid.Row="2"
                              Header="按时间条件重推"
                              Background="White"
                              Padding="10"
                              Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 开始时间 -->
                            <TextBlock Grid.Column="0"
                                       Text="开始时间："
                                       VerticalAlignment="Center"
                                       Margin="0,0,5,0"/>
                            <DatePicker Grid.Column="1"
                                        x:Name="TestTimeDatePicker"
                                        VerticalAlignment="Center"
                                        Margin="0,0,15,0"
                                        SelectedDate="{x:Static System:DateTime.Today}"/>

                            <!-- 传输状态多选 -->
                            <TextBlock Grid.Column="2"
                                       Text="传输状态："
                                       VerticalAlignment="Center"
                                       Margin="0,0,5,0"/>
                            <CheckBox Grid.Column="3"
                                      x:Name="TestState1CheckBox"
                                      Content="待传输(1)"
                                      IsChecked="True"
                                      VerticalAlignment="Center"
                                      Margin="0,0,10,0"/>
                            <CheckBox Grid.Column="4"
                                      x:Name="TestState2CheckBox"
                                      Content="传输中(2)"
                                      IsChecked="True"
                                      VerticalAlignment="Center"
                                      Margin="0,0,10,0"/>
                            <CheckBox Grid.Column="5"
                                      x:Name="TestState4CheckBox"
                                      Content="传输失败(4)"
                                      IsChecked="True"
                                      VerticalAlignment="Center"
                                      Margin="0,0,15,0"/>

                            <!-- 查询按钮 -->
                            <Button Grid.Column="6"
                                    Content="查询"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="TestTimeQueryButton_Click"
                                    x:Name="TestTimeQueryButton"
                                    Margin="0,0,10,0"/>

                            <!-- 循环重推按钮 -->
                            <Button Grid.Column="7"
                                    Content="开始循环重推"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="TestTimeStartButton_Click"
                                    x:Name="TestTimeStartButton"
                                    Background="#107C10"
                                    Margin="0,0,10,0"/>
                            <Button Grid.Column="8"
                                    Content="停止重推"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="TestTimeStopButton_Click"
                                    x:Name="TestTimeStopButton"
                                    IsEnabled="False"
                                    Background="#D13438"
                                    Margin="0,0,10,0"/>

                            <!-- 统计显示 -->
                            <TextBlock Grid.Column="9"
                                       x:Name="TestTimeCountTextBlock"
                                       Text="记录数: 0 | 成功: 0 | 失败: 0"
                                       VerticalAlignment="Center"
                                       Foreground="#333"/>
                        </Grid>
                    </GroupBox>

                    <!-- 日志显示区域 - 双面板 -->
                    <GroupBox Grid.Row="3"
                              Background="White"
                              Padding="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 自动重推日志 -->
                            <GroupBox Grid.Column="0"
                                      Header="自动重推日志"
                                      Margin="0,0,5,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="#E81123" Padding="8,4">
                                        <TextBlock Text="测试环境 - 【正式】客户修改" Foreground="White" FontWeight="Bold"/>
                                    </Border>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5,2">
                                        <TextBlock x:Name="TestStatInit" Text="初次:0" Foreground="#999" Margin="0,0,15,0"/>
                                        <TextBlock x:Name="TestStat" Text="剩余:0 成功:0 跳过:0 失败:0 取消:0" Foreground="#666"/>
                                    </StackPanel>
                                    <TextBox Grid.Row="2"
                                             x:Name="TestLogTextBox"
                                             IsReadOnly="True"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             FontFamily="Consolas"
                                             FontSize="11"
                                             Background="#1E1E1E"
                                             Foreground="#DCDCAA"
                                             TextWrapping="NoWrap"/>
                                </Grid>
                            </GroupBox>

                            <!-- 按时间重推日志 -->
                            <GroupBox Grid.Column="1"
                                      Header="按时间重推日志"
                                      Margin="5,0,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="#107C10" Padding="8,4">
                                        <TextBlock Text="按时间条件重推" Foreground="White" FontWeight="Bold"/>
                                    </Border>
                                    <TextBox Grid.Row="1"
                                             x:Name="TestTimeLogTextBox"
                                             IsReadOnly="True"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             FontFamily="Consolas"
                                             FontSize="11"
                                             Background="#1E1E1E"
                                             Foreground="#6A9955"
                                             TextWrapping="NoWrap"/>
                                </Grid>
                            </GroupBox>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- 放弃传输记录Tab -->
            <TabItem Header="放弃传输记录" x:Name="AbandonTab">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="160"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 区域1：批量放弃 -->
                    <GroupBox Grid.Row="0"
                              Header="批量放弃（今天以前的传输中记录）"
                              Background="White"
                              Padding="15"
                              Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 操作按钮 -->
                            <Button Grid.Row="0" Grid.Column="0"
                                    Content="查询传输中记录"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="AbandonQueryButton_Click"
                                    x:Name="AbandonQueryButton"
                                    Margin="0,0,10,0"/>
                            <Button Grid.Row="0" Grid.Column="1"
                                    Content="执行放弃"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="AbandonExecuteButton_Click"
                                    x:Name="AbandonExecuteButton"
                                    IsEnabled="False"
                                    Background="#D13438"
                                    Margin="0,0,10,0"/>
                            <Button Grid.Row="0" Grid.Column="2"
                                    Content="停止放弃"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="AbandonStopButton_Click"
                                    x:Name="AbandonStopButton"
                                    IsEnabled="False"
                                    Background="#666666"
                                    Margin="0,0,20,0"/>
                            <TextBlock Grid.Row="0" Grid.Column="3"
                                       x:Name="AbandonCountTextBlock"
                                       Text="可放弃记录: 0"
                                       VerticalAlignment="Center"
                                       Foreground="#333"/>
                        </Grid>
                    </GroupBox>

                    <!-- 批量放弃日志 -->
                    <GroupBox Grid.Row="1"
                              Background="White"
                              Padding="5"
                              Margin="0,0,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#6B5B95" Padding="8,4">
                                <TextBlock Text="批量放弃日志" Foreground="White" FontWeight="Bold"/>
                            </Border>
                            <TextBox Grid.Row="1"
                                     x:Name="AbandonLogTextBox"
                                     IsReadOnly="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     FontSize="11"
                                     Background="#1E1E1E"
                                     Foreground="#CE9178"
                                     TextWrapping="NoWrap"/>
                        </Grid>
                    </GroupBox>

                    <!-- 区域2：按客户ID重推传输中记录 -->
                    <GroupBox Grid.Row="2"
                              Header="按客户ID重推传输中记录（使用测试环境Token）"
                              Background="White"
                              Padding="15"
                              Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40"/>
                            </Grid.RowDefinitions>

                            <!-- 客户ID输入 -->
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="客户ID："
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="Bold"/>
                            <TextBox Grid.Row="0" Grid.Column="1"
                                     x:Name="CustomerIdTextBox"
                                     VerticalAlignment="Center"
                                     FontSize="14"
                                     Padding="5"
                                     BorderThickness="2"
                                     BorderBrush="#0078D4"
                                     Background="White"/>
                            <Button Grid.Row="0" Grid.Column="2"
                                    Content="查询并重推"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="RetryByIdButton_Click"
                                    x:Name="RetryByIdButton"
                                    Height="35"
                                    FontSize="14"
                                    Background="#107C10"
                                    Margin="10,0,0,0"/>
                        </Grid>
                    </GroupBox>

                    <!-- 按ID重推日志 -->
                    <GroupBox Grid.Row="3"
                              Background="White"
                              Padding="5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#107C10" Padding="8,4">
                                <TextBlock Text="按ID重推日志" Foreground="White" FontWeight="Bold"/>
                            </Border>
                            <TextBox Grid.Row="1"
                                     x:Name="RetryByIdLogTextBox"
                                     IsReadOnly="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     FontSize="11"
                                     Background="#1E1E1E"
                                     Foreground="#6A9955"
                                     TextWrapping="NoWrap"/>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- 底部状态 -->
        <TextBlock Grid.Row="2"
                   x:Name="GlobalStatusTextBlock"
                   Text="提示：正式环境与测试环境独立运行，各自保存Token"
                   Foreground="#888"
                   FontSize="12"
                   Margin="0,10,0,0"/>
    </Grid>
</Window>