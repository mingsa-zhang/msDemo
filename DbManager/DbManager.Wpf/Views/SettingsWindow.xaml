<Window x:Class="DbManager.Wpf.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="设置" Height="440" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FAFAFA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="#F0F0F0" BorderBrush="#D8D8D8" BorderThickness="0,0,0,1" Padding="14,10">
            <DockPanel>
                <materialDesign:PackIcon Kind="CogOutline" Width="20" Height="20"
                                         Foreground="#555" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="设置" FontSize="14" FontWeight="Medium"
                           Foreground="#333" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- 设置内容 -->
        <ScrollViewer Grid.Row="1" Padding="16" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 外观设置 -->
                <TextBlock Text="外观" FontSize="13" FontWeight="Medium" Foreground="#333" Margin="0,0,0,10"/>
                <Border Background="White" CornerRadius="4" Padding="12" Margin="0,0,0,16"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <StackPanel>
                        <CheckBox Content="暗色主题" FontSize="12" Foreground="#555" Margin="0,4"
                                  IsChecked="{Binding UseDarkTheme}"/>
                    </StackPanel>
                </Border>

                <!-- 编辑器设置 -->
                <TextBlock Text="SQL编辑器" FontSize="13" FontWeight="Medium" Foreground="#333" Margin="0,0,0,10"/>
                <Border Background="White" CornerRadius="4" Padding="12" Margin="0,0,0,16"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <StackPanel>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="字体大小" FontSize="12" VerticalAlignment="Center" Foreground="#555"/>
                            <ComboBox Grid.Column="1" SelectedIndex="{Binding SqlFontSizeIndex}" FontSize="12" Height="28">
                                <ComboBoxItem Content="11"/>
                                <ComboBoxItem Content="12"/>
                                <ComboBoxItem Content="13"/>
                                <ComboBoxItem Content="14"/>
                                <ComboBoxItem Content="15"/>
                                <ComboBoxItem Content="16"/>
                            </ComboBox>
                        </Grid>
                        <Grid Margin="0,8,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="默认分页" FontSize="12" VerticalAlignment="Center" Foreground="#555"/>
                            <ComboBox Grid.Column="1" SelectedIndex="{Binding PageSizeIndex}" FontSize="12" Height="28">
                                <ComboBoxItem Content="50"/>
                                <ComboBoxItem Content="100"/>
                                <ComboBoxItem Content="200"/>
                                <ComboBoxItem Content="500"/>
                                <ComboBoxItem Content="1000"/>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 数据设置 -->
                <TextBlock Text="数据" FontSize="13" FontWeight="Medium" Foreground="#333" Margin="0,0,0,10"/>
                <Border Background="White" CornerRadius="4" Padding="12"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <StackPanel>
                        <CheckBox Content="查询结果自动刷新" FontSize="12" Foreground="#555" Margin="0,4"
                                  IsChecked="{Binding AutoRefreshResults}"/>
                        <CheckBox Content="显示NULL值标记" FontSize="12" Foreground="#555" Margin="0,6,0,4"
                                  IsChecked="{Binding ShowNullMarker}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- 底部按钮 -->
        <Border Grid.Row="2" Padding="12,10" Background="#F0F0F0" BorderBrush="#D8D8D8" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="确定" MinWidth="80" Margin="0,0,10,0" Padding="10,6" FontSize="12"
                        IsDefault="True" Command="{Binding SaveCommand}"/>
                <Button Content="取消" MinWidth="80" Padding="10,6" FontSize="12"
                        IsCancel="True" Command="{Binding CancelCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>