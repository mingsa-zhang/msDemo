<UserControl x:Class="DbManager.Wpf.Views.DataBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <Border Grid.Row="0" Background="#FAFAFA" BorderBrush="#DCDCDC" BorderThickness="0,0,0,1" Padding="4,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 筛选框 -->
                <Grid Grid.Column="0" Margin="2,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="筛选条件 (如: id > 10 AND name LIKE '%test%')"
                             FontSize="12" Padding="4,2" Margin="0,0,4,0"/>
                    <Button Grid.Column="1" ToolTip="应用筛选" Command="{Binding ApplyFilterCommand}"
                            Padding="4,2" Margin="1,0" Style="{StaticResource ToolBarButton}">
                        <materialDesign:PackIcon Kind="Filter" Width="14" Height="14"/>
                    </Button>
                    <Button Grid.Column="2" ToolTip="清除筛选" Command="{Binding ClearFilterCommand}"
                            Padding="4,2" Margin="1,0" Style="{StaticResource ToolBarButton}">
                        <materialDesign:PackIcon Kind="FilterOff" Width="14" Height="14"/>
                    </Button>
                </Grid>

                <!-- 操作按钮 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button ToolTip="刷新" Command="{Binding RefreshCommand}" Padding="6,3" Margin="1,0"
                            Style="{StaticResource ToolBarButton}">
                        <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16"/>
                    </Button>
                    <Separator Margin="4,2"/>
                    <Button ToolTip="编辑模式" Command="{Binding ToggleEditCommand}" Padding="6,3" Margin="1,0"
                            Style="{StaticResource ToolBarButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Pencil" Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding IsEditing, Converter={StaticResource BoolToEditModeTextConverter}}"
                                       Margin="2,0,0,0" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button ToolTip="新增行" Command="{Binding AddRowCommand}" Padding="6,3" Margin="1,0"
                            Style="{StaticResource ToolBarButton}" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}">
                        <materialDesign:PackIcon Kind="Plus" Width="14" Height="14" Foreground="#4CAF50"/>
                    </Button>
                    <Button ToolTip="删除行" Command="{Binding DeleteSelectedRowsCommand}" Padding="6,3" Margin="1,0"
                            Style="{StaticResource ToolBarButton}" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}">
                        <materialDesign:PackIcon Kind="DeleteOutline" Width="14" Height="14" Foreground="#F44336"/>
                    </Button>
                    <Button ToolTip="保存变更" Command="{Binding SaveChangesCommand}" Padding="6,3" Margin="1,0"
                            Style="{StaticResource ToolBarButton}" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}">
                        <materialDesign:PackIcon Kind="ContentSaveOutline" Width="14" Height="14" Foreground="#2196F3"/>
                    </Button>
                    <Separator Margin="4,2"/>
                    <Button ToolTip="导出Excel" Command="{Binding ExportExcelCommand}" Padding="6,3" Margin="1,0"
                            Style="{StaticResource ToolBarButton}">
                        <materialDesign:PackIcon Kind="FileExcelOutline" Width="14" Height="14" Foreground="#4CAF50"/>
                    </Button>
                    <Button ToolTip="导出CSV" Command="{Binding ExportCsvCommand}" Padding="6,3" Margin="1,0"
                            Style="{StaticResource ToolBarButton}">
                        <materialDesign:PackIcon Kind="FileDelimitedOutline" Width="14" Height="14"/>
                    </Button>
                    <Button ToolTip="导出INSERT SQL" Command="{Binding ExportInsertSqlCommand}" Padding="6,3" Margin="1,0"
                            Style="{StaticResource ToolBarButton}">
                        <materialDesign:PackIcon Kind="CodeTags" Width="14" Height="14" Foreground="#FF9800"/>
                    </Button>
                    <Button ToolTip="导出JSON" Command="{Binding ExportJsonCommand}" Padding="6,3" Margin="1,0"
                            Style="{StaticResource ToolBarButton}">
                        <materialDesign:PackIcon Kind="CodeJson" Width="14" Height="14" Foreground="#607D8B"/>
                    </Button>
                    <Separator Margin="4,2"/>
                    <!-- 复制为 -->
                    <Button ToolTip="复制为…" Padding="6,3" Margin="1,0" Style="{StaticResource ToolBarButton}"
                            Click="CopyAsButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentCopy" Width="14" Height="14" VerticalAlignment="Center"/>
                            <materialDesign:PackIcon Kind="MenuDown" Width="12" Height="12" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="复制为 INSERT" Command="{Binding CopyAsInsertCommand}"/>
                                <MenuItem Header="复制为 CSV" Command="{Binding CopyAsCsvCommand}"/>
                                <MenuItem Header="复制为 Markdown" Command="{Binding CopyAsMarkdownCommand}"/>
                                <MenuItem Header="复制为 JSON" Command="{Binding CopyAsJsonCommand}"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 数据表格 -->
        <DataGrid Grid.Row="1"
                  x:Name="DataGrid"
                  ItemsSource="{Binding DataView}"
                  IsReadOnly="{Binding IsEditing, Converter={StaticResource InverseBoolConverter}}"
                  SelectionChanged="DataGrid_SelectionChanged"
                  SelectionMode="Extended"
                  GridLinesVisibility="All"
                  HeadersVisibility="All"
                  AlternatingRowBackground="#F8F8F8"
                  BorderThickness="0"
                  FontSize="12"
                  AutoGenerateColumns="True"
                  CanUserAddRows="False"
                  RowHeaderWidth="42"
                  LoadingRow="DataGrid_LoadingRow"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"/>

        <!-- 底部分页 -->
        <Border Grid.Row="2" Background="#F0F0F0" BorderBrush="#DCDCDC" BorderThickness="0,1,0,0" Padding="8,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" FontSize="11"
                           VerticalAlignment="Center" Foreground="#666"/>

                <!-- 分页按钮 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button ToolTip="上一页" Command="{Binding PreviousPageCommand}" Padding="4,2" Margin="1,0"
                            Style="{StaticResource ToolBarButton}">
                        <materialDesign:PackIcon Kind="ChevronLeft" Width="14" Height="14"/>
                    </Button>
                    <TextBlock Text="{Binding PageInfo}" FontSize="11" VerticalAlignment="Center"
                               Margin="6,0" Foreground="#666"/>
                    <Button ToolTip="下一页" Command="{Binding NextPageCommand}" Padding="4,2" Margin="1,0"
                            Style="{StaticResource ToolBarButton}">
                        <materialDesign:PackIcon Kind="ChevronRight" Width="14" Height="14"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
