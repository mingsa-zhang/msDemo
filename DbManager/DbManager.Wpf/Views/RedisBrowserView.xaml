<UserControl x:Class="DbManager.Wpf.Views.RedisBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具栏：DB 选择 + 键模式 -->
        <Border Grid.Row="0" Background="#FAFAFA" BorderBrush="#DCDCDC" BorderThickness="0,0,0,1" Padding="6,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="DB:" FontSize="12" VerticalAlignment="Center" Margin="2,0,4,0"/>
                <ComboBox ItemsSource="{Binding DatabaseOptions}" SelectedItem="{Binding Database}"
                          FontSize="12" Width="60" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="模式:" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Text="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="12" FontFamily="Consolas" Padding="4,3" Width="220" VerticalContentAlignment="Center"
                         materialDesign:HintAssist.Hint="键模式 (如 user:*)" materialDesign:HintAssist.IsFloating="False">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
                <Button ToolTip="扫描" Command="{Binding SearchCommand}" Padding="6,3" Margin="4,0" Style="{StaticResource ToolBarButton}">
                    <materialDesign:PackIcon Kind="Magnify" Width="16" Height="16"/>
                </Button>
                <Button ToolTip="刷新" Command="{Binding RefreshCommand}" Padding="6,3" Margin="1,0" Style="{StaticResource ToolBarButton}">
                    <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- 键列表 + 值面板 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="150"/>
                <ColumnDefinition Width="3"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ListBox Grid.Column="0" ItemsSource="{Binding Keys}" SelectedItem="{Binding SelectedKey}"
                     FontSize="12" FontFamily="Consolas" BorderThickness="0,0,1,0" BorderBrush="#DCDCDC"
                     VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"/>

            <GridSplitter Grid.Column="1" Width="3" HorizontalAlignment="Stretch" Background="#DCDCDC" Cursor="SizeWE"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="8,4">
                    <DockPanel>
                        <!-- 键操作 -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button ToolTip="编辑值(仅 String)" Command="{Binding EditValueCommand}" Padding="4,2" Margin="1,0" Style="{StaticResource ToolBarButton}">
                                <materialDesign:PackIcon Kind="PencilOutline" Width="14" Height="14"/>
                            </Button>
                            <Button ToolTip="设置 TTL" Command="{Binding SetTtlCommand}" Padding="4,2" Margin="1,0" Style="{StaticResource ToolBarButton}">
                                <materialDesign:PackIcon Kind="TimerOutline" Width="14" Height="14"/>
                            </Button>
                            <Button ToolTip="删除键" Command="{Binding DeleteKeyCommand}" Padding="4,2" Margin="1,0" Style="{StaticResource ToolBarButton}">
                                <materialDesign:PackIcon Kind="DeleteOutline" Width="14" Height="14" Foreground="#F44336"/>
                            </Button>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="键: " FontSize="12" Foreground="#666" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SelectedKey}" FontSize="12" FontWeight="Medium" VerticalAlignment="Center"/>
                            <TextBlock Text="  类型: " FontSize="12" Foreground="#666" VerticalAlignment="Center" Margin="12,0,0,0"/>
                            <TextBlock Text="{Binding ValueType}" FontSize="12" Foreground="#DC382D" FontWeight="Medium" VerticalAlignment="Center"/>
                            <TextBlock Text="  TTL: " FontSize="12" Foreground="#666" VerticalAlignment="Center" Margin="12,0,0,0"/>
                            <TextBlock Text="{Binding TtlText}" FontSize="12" Foreground="#0277BD" FontWeight="Medium" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
                <TextBox Grid.Row="1" Text="{Binding ValueText, Mode=OneWay}" IsReadOnly="True"
                         FontFamily="Consolas" FontSize="12.5" Padding="8"
                         TextWrapping="NoWrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         BorderThickness="0" Background="White"/>
            </Grid>
        </Grid>

        <!-- 状态栏 -->
        <Border Grid.Row="2" Background="#F0F0F0" BorderBrush="#DCDCDC" BorderThickness="0,1,0,0" Padding="8,3">
            <TextBlock Text="{Binding StatusMessage}" FontSize="11.5" Foreground="#666"/>
        </Border>
    </Grid>
</UserControl>
