<Window x:Class="DbManager.Wpf.Views.AddOrEditConnWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{Binding WindowTitle}" Height="620" Width="560"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#FAFAFA">

    <Window.Resources>
        <!-- 分节卡片：一组字段一张卡 -->
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="BorderBrush" Value="#E5E5E5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,12,14,4"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <!-- 行内标签（右对齐、垂直居中） -->
        <Style x:Key="RowLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,8"/>
        </Style>
        <!-- 有边框的输入框（看得出可填写） -->
        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="BorderBrush" Value="#D5D5D5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="InputPassword" TargetType="PasswordBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="BorderBrush" Value="#D5D5D5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="InputCombo" TargetType="ComboBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题栏 -->
        <Border Grid.Row="0" Background="#F0F0F0" BorderBrush="#D8D8D8" BorderThickness="0,0,0,1" Padding="14,10">
            <DockPanel>
                <materialDesign:PackIcon Kind="DatabasePlus" Width="20" Height="20"
                                         Foreground="#555" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="{Binding WindowTitle}" FontSize="14" FontWeight="Medium"
                           Foreground="#333" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- 单页表单 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,12">
            <StackPanel>

                <!-- 数据库类型：可视化卡片 -->
                <TextBlock Text="数据库类型" FontSize="12.5" Foreground="#555" Margin="0,0,0,6"/>
                <ListBox ItemsSource="{Binding DbTypeList}" SelectedItem="{Binding Connection.DbType}"
                         BorderThickness="0" Background="Transparent" Margin="0,0,0,10"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="0,0,8,8"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="CardBorder" Background="White" BorderBrush="#E0E0E0"
                                                BorderThickness="1" CornerRadius="6" Padding="12,8" Width="92">
                                            <StackPanel HorizontalAlignment="Center">
                                                <materialDesign:PackIcon Kind="{Binding Converter={StaticResource DbTypeToIconConverter}}"
                                                                         Width="26" Height="26" HorizontalAlignment="Center"
                                                                         Foreground="#607D8B"/>
                                                <TextBlock Text="{Binding}" FontSize="11" HorizontalAlignment="Center"
                                                           Margin="0,4,0,0" Foreground="#555"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="#1976D2"/>
                                                <Setter TargetName="CardBorder" Property="Background" Value="#E3F2FD"/>
                                                <Setter TargetName="CardBorder" Property="BorderThickness" Value="2"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="#90CAF9"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- 未实现类型提示 -->
                <Border Background="#FFF3E0" BorderBrush="#FFB74D" BorderThickness="1" CornerRadius="4"
                        Margin="0,0,0,10" Padding="10,8"
                        Visibility="{Binding IsDbTypeSupported, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <DockPanel>
                        <materialDesign:PackIcon Kind="AlertOutline" Width="16" Height="16"
                                                 Foreground="#F57C00" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding UnsupportedHint}" Foreground="#E65100"
                                   FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <!-- 连接名称 + 分组 -->
                <Border Style="{StaticResource SectionCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="连接名称" Style="{StaticResource RowLabel}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Connection.Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"
                                 materialDesign:HintAssist.Hint="给这个连接起个名字" materialDesign:HintAssist.IsFloating="False"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="分组" Style="{StaticResource RowLabel}"/>
                        <ComboBox Grid.Row="1" Grid.Column="1" IsEditable="True" ItemsSource="{Binding GroupNames}"
                                  Text="{Binding SelectedGroupName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputCombo}"
                                  materialDesign:HintAssist.Hint="可留空 / 输入新名自动创建" materialDesign:HintAssist.IsFloating="False"/>
                    </Grid>
                </Border>

                <!-- ===== 关系型参数 ===== -->
                <Border Style="{StaticResource SectionCard}" Visibility="{Binding IsRelational, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="78"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="主机" Style="{StaticResource RowLabel}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Connection.Host, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"
                                 materialDesign:HintAssist.Hint="127.0.0.1 或域名" materialDesign:HintAssist.IsFloating="False"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="端口" Style="{StaticResource RowLabel}" Margin="14,0,10,8"/>
                        <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding Connection.Port, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="用户名" Style="{StaticResource RowLabel}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding Connection.UserName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="密码" Style="{StaticResource RowLabel}"/>
                        <PasswordBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Name="PasswordBox" Style="{StaticResource InputPassword}"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="数据库" Style="{StaticResource RowLabel}"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding Connection.DbName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"
                                 materialDesign:HintAssist.Hint="默认数据库（可留空）" materialDesign:HintAssist.IsFloating="False"/>
                    </Grid>
                </Border>

                <!-- ===== SQLite ===== -->
                <Border Style="{StaticResource SectionCard}" Visibility="{Binding IsSQLite, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="文件路径" Style="{StaticResource RowLabel}"/>
                        <TextBox Grid.Column="1" Text="{Binding Connection.SqliteFilePath, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"
                                 materialDesign:HintAssist.Hint="数据库文件的完整路径" materialDesign:HintAssist.IsFloating="False"/>
                    </Grid>
                </Border>

                <!-- ===== Oracle ===== -->
                <Border Style="{StaticResource SectionCard}" Visibility="{Binding IsOracle, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="78"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="主机" Style="{StaticResource RowLabel}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Connection.Host, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="端口" Style="{StaticResource RowLabel}" Margin="14,0,10,8"/>
                        <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding Connection.Port, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="用户名" Style="{StaticResource RowLabel}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding Connection.UserName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="密码" Style="{StaticResource RowLabel}"/>
                        <PasswordBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Name="OraclePasswordBox" Style="{StaticResource InputPassword}"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="服务名" Style="{StaticResource RowLabel}"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding Connection.OracleServiceName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"
                                 materialDesign:HintAssist.Hint="Service Name（如 ORCL）" materialDesign:HintAssist.IsFloating="False"/>
                    </Grid>
                </Border>

                <!-- ===== MongoDB ===== -->
                <Border Style="{StaticResource SectionCard}" Visibility="{Binding IsMongoDB, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="78"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="主机" Style="{StaticResource RowLabel}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Connection.Host, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="端口" Style="{StaticResource RowLabel}" Margin="14,0,10,8"/>
                        <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding Connection.Port, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="用户名" Style="{StaticResource RowLabel}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding Connection.UserName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="密码" Style="{StaticResource RowLabel}"/>
                        <PasswordBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Name="MongoPasswordBox" Style="{StaticResource InputPassword}"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="认证库" Style="{StaticResource RowLabel}"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding Connection.MongoAuthDb, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"
                                 materialDesign:HintAssist.Hint="认证数据库（默认 admin）" materialDesign:HintAssist.IsFloating="False"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="数据库" Style="{StaticResource RowLabel}"/>
                        <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding Connection.DbName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                    </Grid>
                </Border>

                <!-- ===== Redis ===== -->
                <Border Style="{StaticResource SectionCard}" Visibility="{Binding IsRedis, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="78"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="主机" Style="{StaticResource RowLabel}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Connection.Host, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="端口" Style="{StaticResource RowLabel}" Margin="14,0,10,8"/>
                        <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding Connection.Port, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="密码" Style="{StaticResource RowLabel}"/>
                        <PasswordBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Name="RedisPasswordBox" Style="{StaticResource InputPassword}"/>
                    </Grid>
                </Border>

                <!-- ===== 高级（折叠） ===== -->
                <Expander Header="高级" FontSize="12.5" Margin="0,4,0,6" Foreground="#555">
                    <Border Style="{StaticResource SectionCard}" Margin="0,6,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="超时(秒)" Style="{StaticResource RowLabel}"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Connection.ConnectTimeout, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="备注" Style="{StaticResource RowLabel}" VerticalAlignment="Top" Margin="0,4,10,8"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Connection.Description, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource Input}" AcceptsReturn="True" Height="56"
                                     VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top"/>
                        </Grid>
                    </Border>
                </Expander>

                <!-- ===== SSL（折叠） ===== -->
                <Expander Header="SSL" FontSize="12.5" Margin="0,0,0,6" Foreground="#555">
                    <Border Style="{StaticResource SectionCard}" Margin="0,6,0,10">
                        <StackPanel>
                            <CheckBox Content="启用 SSL 加密连接" IsChecked="{Binding Connection.EnableSSL}" Margin="0,0,0,8" FontSize="13"/>
                            <Grid IsEnabled="{Binding Connection.EnableSSL}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="证书路径" Style="{StaticResource RowLabel}"/>
                                <TextBox Grid.Column="1" Text="{Binding Connection.SslCertPath, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Expander>

                <!-- ===== SSH 隧道（折叠） ===== -->
                <Expander Header="SSH 隧道" FontSize="12.5" Margin="0,0,0,4" Foreground="#555">
                    <Border Style="{StaticResource SectionCard}" Margin="0,6,0,10">
                        <StackPanel>
                            <CheckBox Content="通过 SSH 隧道连接" IsChecked="{Binding Connection.UseSsh}" Margin="0,0,0,8" FontSize="13"/>
                            <Grid IsEnabled="{Binding Connection.UseSsh}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="78"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="SSH 主机" Style="{StaticResource RowLabel}"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Connection.SshHost, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="端口" Style="{StaticResource RowLabel}" Margin="14,0,10,8"/>
                                <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding Connection.SshPort, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="用户名" Style="{StaticResource RowLabel}"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding Connection.SshUser, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                                <CheckBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Content="使用私钥文件认证（否则用密码）"
                                          IsChecked="{Binding Connection.SshUseKeyFile}" Margin="0,0,0,8" FontSize="12.5"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="SSH 密码" Style="{StaticResource RowLabel}"/>
                                <PasswordBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" Name="SshPasswordBox" Style="{StaticResource InputPassword}"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="私钥路径" Style="{StaticResource RowLabel}"/>
                                <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding Connection.SshKeyPath, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="私钥口令" Style="{StaticResource RowLabel}"/>
                                <PasswordBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="3" Name="SshPassphraseBox" Style="{StaticResource InputPassword}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Expander>

            </StackPanel>
        </ScrollViewer>

        <!-- 底部按钮区 -->
        <Border Grid.Row="2" Padding="12,10" Background="#F0F0F0" BorderBrush="#D8D8D8" BorderThickness="0,1,0,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#999"/>
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTestSuccess}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Setter Property="Fill" Value="#4CAF50"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsTestSuccess}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Setter Property="Fill" Value="#F44336"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding TestResult}" VerticalAlignment="Center" FontWeight="Medium" FontSize="12" MaxWidth="240" TextTrimming="CharacterEllipsis">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="Foreground" Value="#333"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTestSuccess}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsTestSuccess}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Setter Property="Foreground" Value="#F44336"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="测试连接" Command="{Binding TestConnectionCommand}"
                            MinWidth="100" Margin="0,0,10,0" Padding="10,6" FontSize="12"/>
                    <Button Content="确定" Command="{Binding SaveCommand}"
                            MinWidth="80" Margin="0,0,10,0" Padding="10,6" FontSize="12"/>
                    <Button Content="取消" Command="{Binding CancelCommand}"
                            MinWidth="80" Padding="10,6" FontSize="12"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
