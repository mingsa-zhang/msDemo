<UserControl x:Class="DbManager.Wpf.Views.MongoBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具栏：JSON 过滤 -->
        <Border Grid.Row="0" Background="#FAFAFA" BorderBrush="#DCDCDC" BorderThickness="0,0,0,1" Padding="6,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding FilterJson, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="12" FontFamily="Consolas" Padding="4,3" Margin="0,0,4,0"
                         materialDesign:HintAssist.Hint="过滤 JSON (如 {&quot;age&quot;:{&quot;$gt&quot;:18}})"
                         materialDesign:HintAssist.IsFloating="False">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding ApplyFilterCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
                <Button Grid.Column="1" ToolTip="应用过滤" Command="{Binding ApplyFilterCommand}"
                        Padding="6,3" Margin="1,0" Style="{StaticResource ToolBarButton}">
                    <materialDesign:PackIcon Kind="Filter" Width="14" Height="14"/>
                </Button>
                <Button Grid.Column="2" ToolTip="清除过滤" Command="{Binding ClearFilterCommand}"
                        Padding="6,3" Margin="1,0" Style="{StaticResource ToolBarButton}">
                    <materialDesign:PackIcon Kind="FilterOff" Width="14" Height="14"/>
                </Button>
                <Button Grid.Column="3" ToolTip="刷新" Command="{Binding RefreshCommand}"
                        Padding="6,3" Margin="1,0" Style="{StaticResource ToolBarButton}">
                    <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16"/>
                </Button>
            </Grid>
        </Border>

        <!-- 文档列表 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="White">
            <ItemsControl ItemsSource="{Binding Documents}" Margin="6">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Margin="0,0,0,6" Background="#FCFCFC">
                            <TextBox Text="{Binding Mode=OneWay}" IsReadOnly="True" BorderThickness="0"
                                     Background="Transparent" FontFamily="Consolas" FontSize="12"
                                     TextWrapping="NoWrap" HorizontalScrollBarVisibility="Auto"
                                     Padding="8"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 分页 -->
        <Border Grid.Row="2" Background="#F0F0F0" BorderBrush="#DCDCDC" BorderThickness="0,1,0,0" Padding="8,3">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="{Binding StatusMessage}" FontSize="11.5" Foreground="#666" VerticalAlignment="Center"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button ToolTip="上一页" Command="{Binding PreviousPageCommand}" Padding="4,2" Margin="1,0" Style="{StaticResource ToolBarButton}">
                        <materialDesign:PackIcon Kind="ChevronLeft" Width="16" Height="16"/>
                    </Button>
                    <TextBlock Text="{Binding PageInfo}" FontSize="11.5" Foreground="#666" VerticalAlignment="Center" Margin="6,0"/>
                    <Button ToolTip="下一页" Command="{Binding NextPageCommand}" Padding="4,2" Margin="1,0" Style="{StaticResource ToolBarButton}">
                        <materialDesign:PackIcon Kind="ChevronRight" Width="16" Height="16"/>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
