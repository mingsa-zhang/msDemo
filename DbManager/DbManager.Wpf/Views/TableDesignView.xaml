<UserControl x:Class="DbManager.Wpf.Views.TableDesignView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <Border Grid.Row="0" Background="#FAFAFA" BorderBrush="#DCDCDC" BorderThickness="0,0,0,1" Padding="4,2">
            <StackPanel Orientation="Horizontal">
                <Button ToolTip="新增字段" Command="{Binding AddColumnCommand}" Padding="6,3" Margin="1,0" Style="{StaticResource ToolBarButton}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Width="16" Height="16" VerticalAlignment="Center"/>
                        <TextBlock Text="新增字段" Margin="4,0,0,0" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button ToolTip="删除字段" Command="{Binding DeleteColumnCommand}" Padding="6,3" Margin="1,0" Style="{StaticResource ToolBarButton}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Minus" Width="16" Height="16" VerticalAlignment="Center"/>
                        <TextBlock Text="删除字段" Margin="4,0,0,0" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Separator Margin="4,2"/>
                <Button ToolTip="预览SQL" Command="{Binding GeneratePreviewSqlCommand}" Padding="6,3" Margin="1,0"
                        Style="{StaticResource ToolBarButton}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CodeTags" Width="16" Height="16" VerticalAlignment="Center"/>
                        <TextBlock Text="预览SQL" Margin="4,0,0,0" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Separator Margin="4,2"/>
                <Button ToolTip="保存" Command="{Binding SaveCommand}" Padding="6,3" Margin="1,0"
                        Style="{StaticResource ToolBarButton}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ContentSaveOutline" Width="16" Height="16" VerticalAlignment="Center"/>
                        <TextBlock Text="保存" Margin="4,0,0,0" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- 字段列表 -->
        <DataGrid Grid.Row="1" ItemsSource="{Binding Columns}"
                  SelectedItem="{Binding SelectedColumn}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" FontSize="12"
                  GridLinesVisibility="All"
                  HeadersVisibility="Column"
                  AlternatingRowBackground="#F8F8F8"
                  BorderThickness="0"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling">
            <DataGrid.Columns>
                <DataGridTextColumn Header="字段名" Binding="{Binding ColumnName}" Width="150"/>
                <DataGridTextColumn Header="类型" Binding="{Binding DataType}" Width="120"/>
                <DataGridTextColumn Header="长度" Binding="{Binding MaxLength}" Width="60"/>
                <DataGridCheckBoxColumn Header="主键" Binding="{Binding IsPrimaryKey}" Width="50"/>
                <DataGridCheckBoxColumn Header="可空" Binding="{Binding IsNullable}" Width="50"/>
                <DataGridCheckBoxColumn Header="自增" Binding="{Binding IsAutoIncrement}" Width="50"/>
                <DataGridTextColumn Header="默认值" Binding="{Binding DefaultValue}" Width="100"/>
                <DataGridTextColumn Header="注释" Binding="{Binding Comment}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 分割条 -->
        <GridSplitter Grid.Row="2" Height="3" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                      Background="#DCDCDC" Cursor="SizeNS"/>

        <!-- 底部属性面板 - Navicat风格的字段属性编辑区 -->
        <Expander Grid.Row="3" Header="字段属性" FontSize="11.5" IsExpanded="True"
                  Background="#F0F0F0" BorderBrush="#D8D8D8" BorderThickness="0,1,0,0">
            <Grid Margin="8,6">
                <!-- 未选中列时的提示 -->
                <TextBlock Text="请选择一个字段以查看和编辑属性"
                           FontSize="12" Foreground="#999" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedColumn}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- 属性编辑面板 -->
                <Grid DataContext="{Binding SelectedColumn}">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 字段名 -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="字段名:" VerticalAlignment="Center" FontSize="11" Margin="0,0,6,4"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ColumnName, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="11" Padding="4,3" Margin="0,0,0,4"/>
                    <!-- 类型 -->
                    <TextBlock Grid.Row="0" Grid.Column="3" Text="类型:" VerticalAlignment="Center" FontSize="11" Margin="0,0,6,4"/>
                    <TextBox Grid.Row="0" Grid.Column="4" Text="{Binding DataType, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="11" Padding="4,3" Margin="0,0,0,4"/>

                    <!-- 长度 -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="长度:" VerticalAlignment="Center" FontSize="11" Margin="0,0,6,4"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding MaxLength, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="11" Padding="4,3" Margin="0,0,0,4"/>
                    <!-- 默认值 -->
                    <TextBlock Grid.Row="1" Grid.Column="3" Text="默认值:" VerticalAlignment="Center" FontSize="11" Margin="0,0,6,4"/>
                    <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding DefaultValue, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="11" Padding="4,3" Margin="0,0,0,4"/>

                    <!-- 主键 -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="主键:" VerticalAlignment="Center" FontSize="11" Margin="0,0,6,4"/>
                    <CheckBox Grid.Row="2" Grid.Column="1" IsChecked="{Binding IsPrimaryKey}" VerticalAlignment="Center" Margin="0,0,0,4"/>
                    <!-- 可空 -->
                    <TextBlock Grid.Row="2" Grid.Column="3" Text="可空:" VerticalAlignment="Center" FontSize="11" Margin="0,0,6,4"/>
                    <CheckBox Grid.Row="2" Grid.Column="4" IsChecked="{Binding IsNullable}" VerticalAlignment="Center" Margin="0,0,0,4"/>

                    <!-- 自增 -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="自增:" VerticalAlignment="Center" FontSize="11" Margin="0,0,6,4"/>
                    <CheckBox Grid.Row="3" Grid.Column="1" IsChecked="{Binding IsAutoIncrement}" VerticalAlignment="Center" Margin="0,0,0,4"/>
                    <!-- 注释 -->
                    <TextBlock Grid.Row="3" Grid.Column="3" Text="注释:" VerticalAlignment="Center" FontSize="11" Margin="0,0,6,4"/>
                    <TextBox Grid.Row="3" Grid.Column="4" Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="11" Padding="4,3" Margin="0,0,0,4"/>
                </Grid>
            </Grid>
        </Expander>

        <!-- SQL预览 -->
        <Expander Grid.Row="4" Header="SQL预览" FontSize="11.5" IsExpanded="False"
                  Background="#F0F0F0" BorderBrush="#D8D8D8" BorderThickness="0,1,0,0">
            <TextBox Text="{Binding PreviewSql}" IsReadOnly="True"
                     FontFamily="Consolas" FontSize="12"
                     MinHeight="50" MaxHeight="120"
                     VerticalScrollBarVisibility="Auto"
                     Background="White" BorderThickness="0" Padding="8"/>
        </Expander>
    </Grid>
</UserControl>
