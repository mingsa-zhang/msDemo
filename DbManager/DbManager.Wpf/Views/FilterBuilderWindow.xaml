<Window x:Class="DbManager.Wpf.Views.FilterBuilderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:DbManager.Wpf.ViewModels"
        Title="筛选构建器" Width="640" Height="460"
        WindowStartupLocation="CenterOwner" FontSize="12">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 表头 -->
        <Grid Grid.Row="0" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="32"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="连接" Foreground="#888" FontSize="11"/>
            <TextBlock Grid.Column="1" Text="列" Foreground="#888" FontSize="11" Margin="4,0,0,0"/>
            <TextBlock Grid.Column="2" Text="运算符" Foreground="#888" FontSize="11" Margin="4,0,0,0"/>
            <TextBlock Grid.Column="3" Text="值" Foreground="#888" FontSize="11" Margin="4,0,0,0"/>
        </Grid>

        <!-- 条件行 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Rows}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:FilterConditionRow}">
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="32"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding DataContext.Connectors, RelativeSource={RelativeSource AncestorType=Window}}"
                                      SelectedItem="{Binding Connector}" FontSize="11" Margin="0,0,4,0"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding DataContext.Columns, RelativeSource={RelativeSource AncestorType=Window}}"
                                      SelectedItem="{Binding Column}" IsEditable="True" FontSize="11" Margin="0,0,4,0"/>
                            <ComboBox Grid.Column="2"
                                      ItemsSource="{Binding DataContext.Operators, RelativeSource={RelativeSource AncestorType=Window}}"
                                      SelectedItem="{Binding Operator}" DisplayMemberPath="Display" FontSize="11" Margin="0,0,4,0"/>
                            <TextBox Grid.Column="3" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="11" Padding="3,2" Margin="0,0,4,0"/>
                            <Button Grid.Column="4" ToolTip="删除条件"
                                    Command="{Binding DataContext.RemoveRowCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    Padding="2" Style="{StaticResource SmallIconButton}">
                                <materialDesign:PackIcon Kind="Close" Width="14" Height="14"/>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 添加条件 -->
        <Button Grid.Row="2" HorizontalAlignment="Left" Command="{Binding AddRowCommand}"
                Margin="0,6" Padding="8,3">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Plus" Width="14" Height="14" VerticalAlignment="Center"/>
                <TextBlock Text="添加条件" Margin="4,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>

        <!-- 预览 -->
        <Border Grid.Row="3" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="1" Padding="8" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="WHERE 预览" Foreground="#888" FontSize="11" Margin="0,0,0,4"/>
                <TextBox Text="{Binding PreviewWhere, Mode=OneWay}" IsReadOnly="True"
                         TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"
                         Background="Transparent" BorderThickness="0" MinHeight="30"/>
            </StackPanel>
        </Border>

        <!-- 按钮 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="应用" Width="80" Height="30" Margin="0,0,8,0" IsDefault="True" Click="Ok_Click"/>
            <Button Content="取消" Width="80" Height="30" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
