<Window x:Class="DbManager.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:controls="clr-namespace:DbManager.Wpf.Controls"
        xmlns:views="clr-namespace:DbManager.Wpf.Views"
        xmlns:viewmodels="clr-namespace:DbManager.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="DbManager"
        Height="750" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#FAFAFA">

    <Window.Resources>
        <!-- 标签页右键菜单 -->
        <ContextMenu x:Key="TabContextMenu">
            <MenuItem Header="关闭" Click="CloseTab_Click" InputGestureText="Ctrl+W">
                <MenuItem.Icon>
                    <materialDesign:PackIcon Kind="Close" Width="16" Height="16"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="关闭其他标签" Click="CloseOtherTabs_Click">
                <MenuItem.Icon>
                    <materialDesign:PackIcon Kind="CloseCircleOutline" Width="16" Height="16"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="关闭所有标签" Click="CloseAllTabs_Click">
                <MenuItem.Icon>
                    <materialDesign:PackIcon Kind="CloseBoxOutline" Width="16" Height="16"/>
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== 顶部菜单栏 ===== -->
        <Menu Grid.Row="0" Background="#F0F0F0" FontSize="12" Padding="2,1" Foreground="#333">
            <MenuItem Header="文件(_F)">
                <MenuItem Header="新建连接" Click="Menu_NewConnection" InputGestureText="Ctrl+N">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon Kind="Connection" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="导出连接" Command="{Binding ExportConnectionsCommand}">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon Kind="Export" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="导入连接" Command="{Binding ImportConnectionsCommand}">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon Kind="Import" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="退出" Click="Menu_Exit" InputGestureText="Alt+F4">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon Kind="ExitToApp" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="编辑(_E)">
                <MenuItem Header="新建查询" Click="Menu_NewQuery" InputGestureText="Ctrl+Q">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon Kind="SqlQuery" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="关闭标签" InputGestureText="Ctrl+W" Click="Menu_CloseTab">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon Kind="Close" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="视图(_V)">
                <MenuItem Header="刷新" Click="Menu_Refresh" InputGestureText="Ctrl+R">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="折叠左侧面板" Click="Menu_ToggleLeftPanel">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon Kind="PageLayoutSidebarLeft" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="工具(_T)">
                <MenuItem Header="设置" Click="Menu_Settings" InputGestureText="Ctrl+,">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon Kind="CogOutline" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="帮助(_H)">
                <MenuItem Header="关于 DbManager" Click="Menu_About">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon Kind="InformationOutline" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>

        <!-- ===== 工具栏 - Navicat风格紧凑图标按钮 ===== -->
        <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#DCDCDC" BorderThickness="0,0,0,1" Padding="4,2">
            <StackPanel Orientation="Horizontal">
                <!-- 连接组 -->
                <Button ToolTip="新建连接 (Ctrl+N)" Click="Menu_NewConnection" Padding="6,3" Margin="1,0"
                        Style="{StaticResource ToolBarButton}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Connection" Width="16" Height="16" VerticalAlignment="Center"/>
                        <TextBlock Text="连接" Margin="4,0,0,0" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Separator Margin="4,2"/>
                <!-- 查询组 -->
                <Button ToolTip="新建查询 (Ctrl+Q)" Click="Menu_NewQuery" Padding="6,3" Margin="1,0"
                        Style="{StaticResource ToolBarButton}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="SqlQuery" Width="16" Height="16" VerticalAlignment="Center"/>
                        <TextBlock Text="新建查询" Margin="4,0,0,0" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Separator Margin="4,2"/>
                <!-- 操作组 -->
                <Button ToolTip="刷新 (Ctrl+R)" Command="{Binding RefreshTreeCommand}" Padding="6,3" Margin="1,0"
                        Style="{StaticResource ToolBarButton}">
                    <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16" VerticalAlignment="Center"/>
                </Button>
                <Separator Margin="4,2"/>
                <!-- 导入导出组 -->
                <Button ToolTip="导出连接" Command="{Binding ExportConnectionsCommand}" Padding="6,3" Margin="1,0"
                        Style="{StaticResource ToolBarButton}">
                    <materialDesign:PackIcon Kind="Export" Width="16" Height="16" VerticalAlignment="Center"/>
                </Button>
                <Button ToolTip="导入连接" Command="{Binding ImportConnectionsCommand}" Padding="6,3" Margin="1,0"
                        Style="{StaticResource ToolBarButton}">
                    <materialDesign:PackIcon Kind="Import" Width="16" Height="16" VerticalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- ===== 主内容区 ===== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="180" MaxWidth="450"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧面板：单一连接树 -->
            <Border Grid.Column="0" x:Name="LeftPanel" Background="White" BorderBrush="#DCDCDC" BorderThickness="0,0,1,0">
                <controls:DbTreeControl DataContext="{Binding TreeViewModel}"/>
            </Border>

            <!-- 分割条 -->
            <GridSplitter Grid.Column="1" Width="2" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="#D8D8D8"/>

            <!-- 右侧工作区 -->
            <Grid Grid.Column="2">
                <Grid.Resources>
                    <DataTemplate DataType="{x:Type viewmodels:SqlQueryTabViewModel}">
                        <views:SqlQueryView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:DataBrowserViewModel}">
                        <views:DataBrowserView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:TableDesignViewModel}">
                        <views:TableDesignView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:MongoBrowserViewModel}">
                        <views:MongoBrowserView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:RedisBrowserViewModel}">
                        <views:RedisBrowserView/>
                    </DataTemplate>
                </Grid.Resources>

                <!-- 标签页工作区 -->
                <TabControl ItemsSource="{Binding Tabs}"
                            SelectedItem="{Binding SelectedTab}"
                            FontSize="11"
                            Background="White">
                    <TabControl.Style>
                        <Style TargetType="TabControl">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Tabs.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TabControl.Style>
                    <TabControl.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="0,0,-1,0" ContextMenu="{StaticResource TabContextMenu}">
                                <Button DockPanel.Dock="Right" ToolTip="关闭标签"
                                        Click="CloseTab_Click" Padding="0" Margin="4,0,2,0"
                                        Width="16" Height="16" FontSize="8" Cursor="Hand"
                                        Background="Transparent" BorderThickness="0">
                                    <materialDesign:PackIcon Kind="Close" Width="10" Height="10" Foreground="#999"/>
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="2" Padding="2">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#E0E0E0"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=IsMouseOver}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=IsSelected}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <materialDesign:PackIcon Kind="{Binding IconKind, Converter={StaticResource StringToPackIconKindConverter}}" Width="14" Height="14"
                                                         VerticalAlignment="Center" Margin="0,0,5,0"
                                                         Foreground="#888"/>
                                <TextBlock Text="{Binding Header}" VerticalAlignment="Center" FontSize="11.5"
                                           Margin="0,0,2,0" MaxWidth="160" TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.ContentTemplate>
                        <DataTemplate>
                            <ContentControl Content="{Binding Content}"/>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>

                <!-- 空白首页 -->
                <Grid x:Name="EmptyHomePanel">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Tabs.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,80">
                        <materialDesign:PackIcon Kind="Database" Width="72" Height="72"
                                                 HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="#BDBDBD"/>
                        <TextBlock Text="DbManager" FontSize="26" FontWeight="Light"
                                   HorizontalAlignment="Center" Margin="0,0,0,8" Foreground="#9E9E9E"/>
                        <TextBlock Text="多数据库管理工具" FontSize="14"
                                   HorizontalAlignment="Center" Margin="0,0,0,28" Foreground="#BDBDBD"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                            <Border Background="#E3F2FD" CornerRadius="6" Padding="16,8" Margin="0,0,12,0"
                                    Cursor="Hand" MouseLeftButtonDown="Menu_NewConnection_Click"
                                    BorderBrush="#BBDEFB" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Connection" Width="18" Height="18" VerticalAlignment="Center" Foreground="#1976D2" Margin="0,0,8,0"/>
                                    <TextBlock Text="新建连接" FontSize="13" VerticalAlignment="Center" Foreground="#1976D2"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#E8F5E9" CornerRadius="6" Padding="16,8"
                                    Cursor="Hand" MouseLeftButtonDown="Menu_NewQuery_Click"
                                    BorderBrush="#C8E6C9" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="SqlQuery" Width="18" Height="18" VerticalAlignment="Center" Foreground="#388E3C" Margin="0,0,8,0"/>
                                    <TextBlock Text="新建查询" FontSize="13" VerticalAlignment="Center" Foreground="#388E3C"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="Ctrl+N 新建连接  |  Ctrl+Q 新建查询  |  Ctrl+W 关闭标签  |  F5 执行查询"
                                   FontSize="11" HorizontalAlignment="Center" Foreground="#BDBDBD"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>

        <!-- ===== 底部状态栏 ===== -->
        <Border Grid.Row="3" Background="#F0F0F0" BorderBrush="#D8D8D8" BorderThickness="0,1,0,0" Padding="10,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Ellipse Width="7" Height="7" Fill="#4CAF50" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Text="就绪" FontSize="11" VerticalAlignment="Center" Foreground="#666"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" FontSize="11"
                           VerticalAlignment="Center" Foreground="#888" Margin="10,0,0,0"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,12,0">
                    <materialDesign:PackIcon Kind="Connection" Width="12" Height="12"
                                             VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#999"/>
                    <TextBlock Text="{Binding ConnectionCount, StringFormat='{}{0} 连接'}" FontSize="11"
                               VerticalAlignment="Center" Foreground="#888"/>
                </StackPanel>
                <TextBlock Grid.Column="3" Text="DbManager v1.0" FontSize="11"
                           VerticalAlignment="Center" Foreground="#AAA"/>
            </Grid>
        </Border>
    </Grid>
</Window>
